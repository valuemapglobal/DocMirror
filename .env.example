# DocMirror — example env vars (copy to .env, edit; do not commit .env)
# Usage: source .env  or  export $(grep -v '^#' .env | xargs)

# ── External OCR (low-quality images/scans route through external OCR model) ──
# When enabled, auto-calls the external API when image quality falls below the threshold; otherwise uses built-in RapidOCR.
DOCMIRROR_EXTERNAL_OCR_PROVIDER=docmirror.ocr.aistudio_provider:call_aistudio_layout_ocr
DOCMIRROR_EXTERNAL_OCR_QUALITY_THRESHOLD=80
DOCMIRROR_AISTUDIO_OCR_API_URL=https://XXXX.com/layout-parsing
DOCMIRROR_AISTUDIO_OCR_TOKEN=your-token-here
