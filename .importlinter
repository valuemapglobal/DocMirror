# DocMirror Import Dependency Contract
#
# Generated from docmirror/configs/architecture/clean_manifest.yaml.
# Run: python3 scripts/validate/generate_import_linter.py --check

[importlinter]
root_package = docmirror

include_external_packages = True

[importlinter:manifest_forbidden_1_input]
name = Clean manifest forbidden imports for input
type = forbidden
source_modules =
    docmirror.input
forbidden_modules =
    docmirror.server
    docmirror.cli
    docmirror.sdk
allow_indirect_imports = True

[importlinter:manifest_forbidden_2_output]
name = Clean manifest forbidden imports for output
type = forbidden
source_modules =
    docmirror.output
forbidden_modules =
    docmirror.server
    docmirror.cli
    docmirror.sdk
allow_indirect_imports = True

[importlinter:manifest_forbidden_3_plugins]
name = Clean manifest forbidden imports for plugins
type = forbidden
source_modules =
    docmirror.plugins
forbidden_modules =
    docmirror.input.extraction.extractor
    docmirror.layout.segment.zones
    docmirror.tables.engine
    docmirror.ocr.fallback
    docmirror.server
    docmirror.cli
allow_indirect_imports = True

[importlinter:manifest_forbidden_4_models]
name = Clean manifest forbidden imports for models
type = forbidden
source_modules =
    docmirror.models
forbidden_modules =
    docmirror.input
    docmirror.output
    docmirror.server
    docmirror.cli
    docmirror.plugins
allow_indirect_imports = True
ignore_imports =
    docmirror.models.mirror.serialization_contract -> docmirror.evidence.structure_provenance
    docmirror.models.mirror.serialization_contract -> docmirror.tables.compose.ledger_quality
    docmirror.models.mirror.serialization_contract -> docmirror.layout.vocabulary
